# KafGraph Configuration
# Copy to .env and adjust values for local development

# Server
KAFGRAPH_HOST=0.0.0.0
KAFGRAPH_PORT=7474
KAFGRAPH_BOLT_PORT=7687

# Storage
KAFGRAPH_DATA_DIR=./data
KAFGRAPH_STORAGE_ENGINE=badger

# Kafka
KAFGRAPH_KAFKA_BROKERS=localhost:9092
KAFGRAPH_KAFKA_GROUP_ID=kafgraph
KAFGRAPH_KAFKA_TOPIC_PREFIX=group

# MinIO / S3
KAFGRAPH_S3_ENDPOINT=localhost:9000
KAFGRAPH_S3_ACCESS_KEY=minioadmin
KAFGRAPH_S3_SECRET_KEY=minioadmin
KAFGRAPH_S3_BUCKET=kafgraph
KAFGRAPH_S3_USE_SSL=false

# Embedding
KAFGRAPH_EMBEDDING_ENDPOINT=http://localhost:11434
KAFGRAPH_EMBEDDING_MODEL=nomic-embed-text

# Logging
KAFGRAPH_LOG_LEVEL=info
KAFGRAPH_LOG_FORMAT=json

# Metrics
KAFGRAPH_METRICS_PORT=9090
